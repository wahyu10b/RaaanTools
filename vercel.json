{
  "version": 2,
  "functions": {
    "api/app.php": {
      "runtime": "vercel-php@0.7.4"
    },
    "api/index.php": {
      "runtime": "vercel-php@0.7.4"
    },
    "api/token.php": {
      "runtime": "vercel-php@0.7.4"
    }
  },
  "routes": [
    {
      "src": "/asset/(.*)",
      "dest": "/asset/$1"
    },
    {
      "src": "/css/(.*)",
      "dest": "/css/$1"
    },
    {
      "src": "/script/(.*)",
      "dest": "/script/$1"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/api/app.php"
    }
  ],
  "env": {
    "RAAAN_API_BASE": "https://api.pixxxry.eu.cc"
  }
}
